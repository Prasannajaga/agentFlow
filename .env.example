# Option 1: provide a full SQLAlchemy URL
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/flow_agent

# Option 2: provide local Postgres parts and let AgentFlow build DATABASE_URL
DATABASE_DRIVER=postgresql+psycopg
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=flow_agent
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Optional worker operational settings
# WORKER_HEARTBEAT_INTERVAL_SECONDS=5
# WORKER_STALE_THRESHOLD_SECONDS=600
